---
export const prerender = false;
import ChildLayout from "@/layouts/ChildLayout.astro";
import { ChildActivitiesView } from "@/components/pages/ChildActivitiesView";

const { id } = Astro.params;
const user = (Astro.locals as any).user;
const userRoles = user?.roles || [];

// Solo cuidadores y el mismo niño pueden ver esta página
const isCaregiver = userRoles.includes('CAREGIVER');
const isChild = userRoles.includes('CHILD');
const isSameChild = isChild && user.id === parseInt(id || '0');

if (!isCaregiver && !isSameChild) {
  return Astro.redirect('/login');
}

// Obtener datos del niño
let childData = null;
try {
  const response = await fetch(`${import.meta.env.PUBLIC_API_URL || 'http://localhost:8080'}/api/children/${id}`, {
    headers: {
      'Authorization': `Bearer ${(Astro.cookies.get('token')?.value || '')}`,
    },
  });

  if (response.ok) {
    childData = await response.json();
  }
} catch (error) {
  console.error('Error fetching child data:', error);
}

if (!childData) {
  return Astro.redirect('/inicio-cuidador');
}
---
<ChildLayout title={`EnfoKids - Actividades de ${childData.firstName}`}>
  <ChildActivitiesView
    client:load
    childId={childData.id}
    childName={`${childData.firstName} ${childData.lastName}`}
  />
</ChildLayout>
