---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { DashboardHome } from "./DashboardHome";

const user = (Astro.locals as any).user ? {
  firstName: (Astro.locals as any).user.firstName,
  lastName: (Astro.locals as any).user.lastName,
  email: (Astro.locals as any).user.email,
} : undefined;
---
<AdminLayout title="EnfoKids - Inicio">
  <DashboardHome client:load user={user} />
</AdminLayout>